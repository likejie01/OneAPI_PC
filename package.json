{
  "name": "oneapi-pc",
  "private": true,
  "version": "0.1.5",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite --configLoader native",
    "dev:electron": "concurrently -k \"npm:dev\" \"npm:electron\"",
    "electron": "wait-on tcp:5173 && electron .",
    "build": "tsc -b && vite build --configLoader native",
    "build:win": "cross-env-shell ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ \"node scripts/prepare-win-icons.mjs && npm run build && electron-builder --win --x64 && node scripts/finalize-win-release.mjs\"",
    "build:mac": "node scripts/prepare-mac-icons.mjs && npm run build && electron-builder --mac dmg zip --x64 --arm64 --publish never",
    "test": "node --test --experimental-strip-types \"src/**/*.test.ts\"",
    "lint": "eslint .",
    "preview": "vite preview --configLoader native"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "clsx": "^2.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "dayjs": "^1.11.20",
    "electron-updater": "^6.8.3",
    "lucide-react": "^1.16.0",
    "mermaid": "^11.15.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "vite-plugin-electron": "^0.29.1",
    "wait-on": "^9.0.10",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "png-to-ico": "^3.0.1",
    "rcedit": "^5.0.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-electron-renderer": "^0.14.7"
  },
  "build": {
    "appId": "com.oneapi.pc",
    "productName": "OneAPI PC",
    "icon": "build/icon.ico",
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "toolsets": {
      "winCodeSign": "1.1.0"
    },
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../shared-cli-catalog",
        "to": "cli-catalog"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        "nsis",
        "portable"
      ]
    },
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "OneAPI_PC-${version}-${arch}.${ext}"
    },
    "afterPack": "scripts/electron-builder-after-pack.cjs",
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "OneAPI_PC_Setup-1-0.${ext}",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    },
    "portable": {
      "artifactName": "OneAPI_PC-1-0.${ext}"
    }
  }
}
